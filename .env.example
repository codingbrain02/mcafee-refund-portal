VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-public-anon-key

# Keep the database password local. Store service-role, Resend, and future
# banking credentials only in Vercel secrets or an approved secrets manager.
SUPABASE_SERVICE_ROLE_KEY=server-only
SUPABASE_DB_PASSWORD=server-only
SUPABASE_URL=https://your-project-ref.supabase.co
RESEND_API_KEY=server-only
RESEND_FROM_EMAIL="Refund Portal <onboarding@resend.dev>"

# Optional Sentry monitoring. Runtime capture stays disabled while DSNs are blank.
VITE_SENTRY_DSN=
SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0
SENTRY_TRACES_SAMPLE_RATE=0
VITE_APP_RELEASE=
SENTRY_RELEASE=

# Optional source-map upload credentials. SENTRY_AUTH_TOKEN is server/build only.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Optional server-to-server authorization. Automatic portal dispatch does not
# require a cron scheduler.
NOTIFICATION_CRON_SECRET=server-only
CRON_SECRET=server-only

# Leave banking values blank until the organization receives authorized API
# credentials from its bank or payment provider.
AUTHORIZED_BANK_API_BASE_URL=
AUTHORIZED_BANK_API_CLIENT_ID=
AUTHORIZED_BANK_API_CLIENT_SECRET=
